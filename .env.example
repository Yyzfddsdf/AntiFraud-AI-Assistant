# 反诈卫士（Sentinel AI）环境变量配置
# 复制此文件为 .env 并填入你的实际密钥

# ============================================
# JWT 密钥（生产环境必须设置强密钥）
# ============================================
JWT_SECRET=your_jwt_secret_here

# 管理员升级邀请码
INVITE_CODE_ADMIN=your_admin_invite_code_here

# ============================================
# 智能体 API Keys
# ============================================
AGENT_MAIN_API_KEY=your_deepseek_api_key_here
AGENT_IMAGE_API_KEY=your_qwen_api_key_here
AGENT_IMAGE_QUICK_API_KEY=your_qwen_api_key_here
AGENT_VIDEO_API_KEY=your_qwen_api_key_here
AGENT_AUDIO_API_KEY=your_qwen_api_key_here
AGENT_ASR_API_KEY=your_qwen_api_key_here
AGENT_CASE_COLLECTION_API_KEY=your_deepseek_api_key_here
AGENT_SIMULATION_QUIZ_API_KEY=your_deepseek_api_key_here

# ============================================
# Embedding API Key
# ============================================
EMBEDDING_API_KEY=your_qwen_api_key_here

# ============================================
# 聊天助手 API Keys
# ============================================
CHAT_API_KEY=your_qwen_api_key_here
ADMIN_CHAT_API_KEY=your_qwen_api_key_here

# ============================================
# Tavily 搜索 API Key
# ============================================
TAVILY_API_KEY=your_tavily_api_key_here

# ============================================
# 数据库路径（可选，使用默认值可不填）
# ============================================
# DB_PATH=DB/auth_system.db
# HISTORICAL_CASE_DB_PATH=DB/historical_case_library.db

# ============================================
# 服务端口（可选，默认 8081）
# ============================================
# PORT=8081
